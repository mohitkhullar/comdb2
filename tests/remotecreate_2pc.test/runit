########################################
# TEST 9: Crash after PREPARED sent — coordinator commits
#
# Participant (tertiary) sends CDB2_DIST__PREPARED then crashes.
# Coordinator receives PREPARED from all 4 participants and decides COMMIT.
# On restart, disttxn_resolve_ddl_prepared() contacts the coordinator,
# learns COMMIT, prunes the prepared txn (gap: not re-committed).
# The schema change resume mechanism picks up the sc_list in llmeta
# and re-runs finalize_schema_change() on the tertiary.
# Expected: table eventually exists on ALL shards.
########################################
function test_crash_after_prepared_commit
{
    echo "=== TEST: test_crash_after_prepared_commit ==="

    [[ -z "$CLUSTER" ]] && { echo "SKIP: requires cluster"; return; }

    setup_testcase

    typeset master=$(find_tertiary_master)
    [[ -z "$master" ]] && { fail_exit "test_crash_after_prepared_commit: cannot find tertiary master"; return; }

    echo "Tertiary master: $master"

    # Crash tertiary after it sends PREPARED to coordinator.
    # Coordinator is NOT killed — it will receive PREPARED from all 4 and commit.
    $CDB2SQL_EXE $TERTIARY_CDB2_OPTIONS $TERTIARY_DBNAME --host $master \
        "put tunable debug_exit_participant_after_prepare '1'"

    kill_restart_cluster $TERTIARY_DBNAME "$TERTIARY_CDB2_OPTIONS" $TERTIARY_DBDIR 5 &
    local kill_pid=$!

    echo "Running CREATE TABLE with 2PC (tertiary will crash after PREPARED)..."
    $P_SQL "create table t(a int unique, b int) partitioned by columns(a) on (${shards})" 2>&1
    local create_rc=$?
    echo "Create returned rc=$create_rc"

    wait $kill_pid

    echo "Waiting for tertiary to restart..."
    block_until_cluster_is_up $TERTIARY_DBNAME "$TERTIARY_CDB2_OPTIONS" 120
    if (( $? != 0 )); then
        fail_exit "test_crash_after_prepared_commit: tertiary did not come up (possible deadlock)"
        return
    fi

    allow_coordinator_all

    # disttxn_resolve_ddl_prepared() on tertiary learned COMMIT from coordinator.
    # The prepared BDB txn was pruned (not re-committed).
    # sc_list in llmeta triggers schema change resume → finalize_schema_change() runs.
    # Wait up to 60s for the resume to complete and the table to appear.
    echo "Waiting for schema change resume to finalize on tertiary (up to 60s)..."
    local waited=0
    local resume_ok=0
    while (( waited < 60 )); do
        $S2_SQL "select 1 from t limit 1" 2>/dev/null && { resume_ok=1; break; }
        sleep 2
        waited=$((waited + 2))
    done

    if (( resume_ok == 0 )); then
        fail_exit "test_crash_after_prepared_commit: table 't' did not appear on tertiary after resume (schema change resume failed)"
        return
    fi

    echo "Table appeared on tertiary after resume. Verifying all shards..."
    verify_table "t"
    [[ -f $stopfile ]] && return

    $P_SQL "drop table t" 2>/dev/null
    echo "test_crash_after_prepared_commit PASSED"
}

########################################
# TEST 10: Crash after PREPARED sent — coordinator aborts (timeout)
#
# Participant (tertiary) sends CDB2_DIST__PREPARED then crashes.
# Primary (coordinator) is also killed immediately after the tertiary crashes,
# before it can send its decision back to the tertiary.
# On restart, tertiary's disttxn_resolve_ddl_prepared() cannot reach the
# coordinator → DDL_RESOLVE_TIMEOUT_SEC (30s) timeout.
# With disttxn_ddl_resolve_fatal=0 (written to lrl before restart),
# the DDL txn is aborted and startup continues cleanly.
# Expected: tertiary comes up without deadlock, table NOT on tertiary.
########################################
function test_crash_after_prepared_abort
{
    echo "=== TEST: test_crash_after_prepared_abort ==="

    [[ -z "$CLUSTER" ]] && { echo "SKIP: requires cluster"; return; }

    setup_testcase

    typeset tertiary_master=$(find_tertiary_master)
    [[ -z "$tertiary_master" ]] && { fail_exit "test_crash_after_prepared_abort: cannot find tertiary master"; return; }

    # Write disttxn_ddl_resolve_fatal=0 to lrl so tertiary aborts (not fatal)
    # on coordinator timeout during restart.
    echo "disttxn_ddl_resolve_fatal 0" >> $TERTIARY_DBDIR/${TERTIARY_DBNAME}.lrl

    # Enable crash-after-prepare on tertiary
    $CDB2SQL_EXE $TERTIARY_CDB2_OPTIONS $TERTIARY_DBNAME --host $tertiary_master \
        "put tunable debug_exit_participant_after_prepare '1'"

    # Kill tertiary after prepare (3s delay, 5s sleep before restart)
    kill_restart_cluster $TERTIARY_DBNAME "$TERTIARY_CDB2_OPTIONS" $TERTIARY_DBDIR 5 &
    local kill_pid=$!

    # Kill coordinator (primary) ~4s after start so tertiary crashes first,
    # then coordinator goes down so tertiary can't contact it on restart.
    (
        sleep 4
        for node in $CLUSTER; do
            kill -9 $(cat ${TMPDIR}/${DBNAME}.${node}.pid) 2>/dev/null
        done
    ) &
    local coord_kill_pid=$!

    echo "Running CREATE TABLE (tertiary will crash after PREPARED, coordinator killed after)..."
    $P_SQL "create table t(a int unique, b int) partitioned by columns(a) on (${shards})" 2>&1
    local create_rc=$?
    echo "Create returned rc=$create_rc (expected non-zero)"

    wait $kill_pid
    wait $coord_kill_pid

    # Restart coordinator (primary) — do this AFTER tertiary has started its
    # resolve window so tertiary still times out (coordinator was down during
    # the DDL_RESOLVE_TIMEOUT_SEC window).
    sleep 35
    for node in $CLUSTER; do
        PARAMS="$DBNAME --no-global-lrl"
        REP_ENV_VARS="${DBDIR}/replicant_env_vars"
        if [ $node == $(hostname) ]; then
            mv --backup=numbered $LOGDIR/${DBNAME}.${node}.db $LOGDIR/${DBNAME}.${node}.db.old 2>/dev/null
            ${COMDB2_EXE} ${PARAMS} --lrl $DBDIR/${DBNAME}.lrl \
                --pidfile ${TMPDIR}/${DBNAME}.${node}.pid 2>&1 \
                | gawk '{ print strftime("%H:%M:%S>"), $0; fflush(); }' \
                >>$LOGDIR/${DBNAME}.${node}.db 2>&1 &
        else
            mv --backup=numbered $LOGDIR/${DBNAME}.${node}.db $LOGDIR/${DBNAME}.${node}.db.old 2>/dev/null
            CMD="source ${REP_ENV_VARS} ; ${COMDB2_EXE} ${PARAMS} --lrl $DBDIR/${DBNAME}.lrl --pidfile ${TMPDIR}/${DBNAME}.pid"
            ssh -o StrictHostKeyChecking=no -tt $node ${CMD} 2>&1 </dev/null \
                > >(gawk '{ print strftime("%H:%M:%S>"), $0; fflush(); }' >>$LOGDIR/${DBNAME}.${node}.db) &
            echo $! > ${TMPDIR}/${DBNAME}.${node}.pid
        fi
    done

    echo "Waiting for tertiary to come back up (with disttxn_ddl_resolve_fatal=0)..."
    block_until_cluster_is_up $TERTIARY_DBNAME "$TERTIARY_CDB2_OPTIONS" 120
    if (( $? != 0 )); then
        fail_exit "test_crash_after_prepared_abort: tertiary did not come up"
        return
    fi

    echo "Waiting for coordinator (primary) to come back up..."
    block_until_cluster_is_up $DBNAME "$CDB2_OPTIONS" 120
    if (( $? != 0 )); then
        fail_exit "test_crash_after_prepared_abort: coordinator did not come back up"
        return
    fi

    allow_coordinator_all
    sleep 5

    # Tertiary timed out waiting for coordinator → aborted DDL txn.
    # Table must NOT exist on tertiary.
    $S2_SQL "select 1 from t limit 1" 2>/dev/null
    if (( $? == 0 )); then
        fail_exit "test_crash_after_prepared_abort: table 't' exists on tertiary after abort — not clean"
        return
    fi

    echo "Table correctly absent on tertiary after abort."

    # Remove the lrl override
    sed -i '/disttxn_ddl_resolve_fatal 0/d' $TERTIARY_DBDIR/${TERTIARY_DBNAME}.lrl

    # Reset tunable on tertiary
    typeset new_master=$(find_tertiary_master)
    [[ -n "$new_master" ]] && \
        $CDB2SQL_EXE $TERTIARY_CDB2_OPTIONS $TERTIARY_DBNAME --host $new_master \
            "put tunable disttxn_ddl_resolve_fatal '1'" 2>/dev/null

    echo "test_crash_after_prepared_abort PASSED"
}

