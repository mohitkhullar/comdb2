    $P_SQL "alter table ta add column c int"
    if (( $? != 0 )); then
        fail_exit "test_alter_add_column: alter failed"
        return
    fi

    # Verify column c exists on all shards
    $S0_SQL "select c from ta limit 1" 2>/dev/null
